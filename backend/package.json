{
  "name": "mente-activa-backend",
  "version": "1.0.0",
  "description": "API REST – Mente Activa",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage --forceExit",
    "lint": "eslint src/**/*.js"
  },
"jest": {
  "testEnvironment": "node",
  "globalSetup": "./src/__tests__/globalSetup.js",
  "globalTeardown": "./src/__tests__/globalTeardown.js",
  "testMatch": ["**/*.test.js"],
  "forceExit": true,
  "coverageThreshold": {
    "global": { "lines": 85 }
  }
},
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.3.0",
    "jest": "^29.x",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.3",
    "supertest": "^7.x"
  }
}
